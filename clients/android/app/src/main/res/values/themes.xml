<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Sola" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/sola_primary</item>
        <item name="colorOnPrimary">@color/sola_on_primary</item>
        <item name="colorPrimaryDark">@color/sola_primary_dark</item>
        <item name="android:statusBarColor">@color/sola_primary_dark</item>
    </style>

    <!-- Keeps the toolbar overflow icon dark on the blue bar in both light and
         dark mode (default control color would flip with the theme). The title
         color is set directly via app:titleTextColor in the layout. NOTE: we do
         NOT override textColorPrimary here — doing so leaks into the overflow
         popup and makes its menu text unreadable. -->
    <style name="ThemeOverlay.Sola.Toolbar" parent="ThemeOverlay.Material3.Toolbar.Surface">
        <item name="colorControlNormal">@color/sola_on_primary</item>
    </style>

    <!-- Standard popup styling so the overflow menu uses readable default
         (theme-aware) text/background, independent of the blue bar. -->
    <style name="ThemeOverlay.Sola.Popup" parent="ThemeOverlay.Material3" />
</resources>
